{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "./dist",
    "module": "nodenext",
    "moduleResolution": "nodenext"
  },
  "include": [
    "infrastructure/**/*",
    "modules/**/*",
    "core/**/*",
    "shared/**/*",
    "scripts/**/*"
  ],
  "exclude": [
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}
