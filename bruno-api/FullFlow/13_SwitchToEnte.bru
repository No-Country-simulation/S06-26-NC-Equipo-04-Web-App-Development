meta {
  name: 13 - Login as Ente
  type: http
  seq: 17
}

post {
  url: {{baseUrl}}/api/auth/login
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "{{entEmail}}",
    "password": "Test123456!"
  }
}

script:post-response {
  if (res.status === 200) {
    const data = res.body.data;
    bru.setVar('token', data.token);
  }
}
