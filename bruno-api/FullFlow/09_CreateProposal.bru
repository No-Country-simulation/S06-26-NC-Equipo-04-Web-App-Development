meta {
  name: 09 - Create Proposal
  type: http
  seq: 13
}

post {
  url: {{baseUrl}}/api/tenders/{{tenderId}}/proposals
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{token}}
  Content-Type: application/json
}

body:json {
  {}
}

script:post-response {
  if (res.status === 201) {
    const data = res.body.data;
    bru.setVar('proposalId', data.id);
  }
}
