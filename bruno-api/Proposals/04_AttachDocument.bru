meta {
  name: Attach Document to Proposal
  type: http
  seq: 4
}

put {
  url: {{baseUrl}}/api/tenders/{{tenderId}}/proposals/{{proposalId}}/documents
  body: multipart-form
  auth: none
}

headers {
  Authorization: Bearer {{token}}
}

body:multipart-form {
  file: @file(./test-proposal.pdf)
  requirementId: {{reqId}}
}
