meta {
  name: Upload Document
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/tenders/{{tenderId}}/documents
  body: multipart-form
  auth: none
}

headers {
  Authorization: Bearer {{token}}
}

body:multipart-form {
  file: @file(./test-base.pdf)
  documentType: BASE
}

script:post-response {
  if (res.status === 201) {
    const data = res.body.data;
    bru.setVar('docId', data.id);
  }
}
