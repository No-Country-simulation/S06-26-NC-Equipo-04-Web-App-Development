meta {
  name: Get User
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/api/users/{{userId}}
  body: none
  auth: none
}

headers {
  Authorization: Bearer {{token}}
  Content-Type: application/json
}

script:post-response {
  if (res.status === 200) {
    const data = res.body.data;
    bru.setVar('userId', data.id);
  }
}
