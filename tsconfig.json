{
  "compilerOptions": {
    "target": "ES2017",
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {

      }
    ],
"paths": {
      "@/*": ["./*"],
      "@infrastructure/*": ["./infrastructure/*"],
      "@shared/*": ["./shared/*"],
      "@app/*": ["./app/*"],
      "@modules/*": ["./modules/*"],
      "@core/*": ["./core/*"]
    }
  },
  "include": [
    "**/*.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.mts"
  ],
  "exclude": ["node_modules", "vitest.config.ts"]
}